#!/usr/bin/env php
<?php
declare(strict_types=1);

$root = realpath(__DIR__ . '/../..');
$args = array_slice($argv, 1);
$cmd  = $args[0] ?? 'help';

function run(string $command): string {
    $out = [];
    $code = 0;
    exec($command . ' 2>&1', $out, $code);
    return implode("\n", $out);
}

function root(): string {
    return realpath(__DIR__ . '/../..');
}

switch ($cmd) {
    case 'scan':
        echo "# Project scan\n\n";
        echo "## Git status\n";
        echo run('cd ' . escapeshellarg(root()) . ' && git status --short') . "\n\n";

        echo "## Tree\n";
        echo run('cd ' . escapeshellarg(root()) . ' && find src tests docs -maxdepth 4 -type f | sort') . "\n";
        break;

    case 'grep':
        $q = $args[1] ?? '';
        if ($q === '') {
            fwrite(STDERR, "Usage: period-wp-kit-agent grep <pattern>\n");
            exit(1);
        }
        echo run('cd ' . escapeshellarg(root()) . ' && rg -n ' . escapeshellarg($q) . ' src tests docs');
        break;

    case 'pack':
        $files = array_slice($args, 1);
        if (!$files) {
            fwrite(STDERR, "Usage: period-wp-kit-agent pack <file> [file...]\n");
            exit(1);
        }

        foreach ($files as $file) {
            $path = root() . '/' . ltrim($file, '/');
            if (!is_file($path)) {
                fwrite(STDERR, "Skip missing file: {$file}\n");
                continue;
            }

            echo "\n===== FILE: {$file} =====\n";
            echo file_get_contents($path);
            echo "\n===== END FILE: {$file} =====\n";
        }
        break;

    case 'test':
        echo run('cd ' . escapeshellarg(root()) . ' && composer test');
        break;

    case 'roadmap':
        $path = root() . '/docs/development-roadmap.md';
        if (!is_file($path)) {
            fwrite(STDERR, "Warning: docs/development-roadmap.md not found\n");
            exit(1);
        }
        echo file_get_contents($path);
        break;

    case 'architecture':
        $files = glob(root() . '/docs/architecture-*.md');
        if (!$files) {
            fwrite(STDERR, "Warning: no docs/architecture-*.md files found\n");
            exit(1);
        }
        sort($files);
        foreach ($files as $path) {
            $name = basename($path);
            echo "\n===== {$name} =====\n\n";
            echo file_get_contents($path);
            echo "\n===== END {$name} =====\n";
        }
        break;

    case 'context':
        $topic = $args[1] ?? '';
        if ($topic === '') {
            fwrite(STDERR, "Usage: period-wp-kit-agent context <topic>\n");
            exit(1);
        }

        $contexts = [
            'PostAssets' => [
                'docs/development-roadmap.md',
                'docs/architecture-post-assets.md',
                'src/WordPress/PostAssets.php',
                'src/WordPress/PostAssetsRenderer.php',
                'src/WordPress/PostAssetsCompileResult.php',
                'src/WordPress/PostAssetsCompilerInterface.php',
                'src/WordPress/PostAssetsCompileService.php',
                'src/WordPress/NullPostAssetsCompiler.php',
                'src/WordPress/ScssPhpPostAssetsCompiler.php',
                'src/WordPress/PostMetaManager.php',
                'tests/WordPress/PostAssetsTest.php',
                'tests/WordPress/PostAssetsCompileServiceTest.php',
                'tests/WordPress/NullPostAssetsCompilerTest.php',
                'tests/WordPress/ScssPhpPostAssetsCompilerTest.php',
            ],
        ];

        if (!isset($contexts[$topic])) {
            fwrite(STDERR, "Unknown topic: {$topic}\n");
            fwrite(STDERR, "Available topics: " . implode(', ', array_keys($contexts)) . "\n");
            exit(1);
        }

        foreach ($contexts[$topic] as $file) {
            $path = root() . '/' . $file;
            if (!is_file($path)) {
                fwrite(STDERR, "Warning: missing file: {$file}\n");
                continue;
            }
            echo "\n===== FILE: {$file} =====\n";
            echo file_get_contents($path);
            echo "\n===== END FILE: {$file} =====\n";
        }
        break;

    case 'impact':
        $topic = $args[1] ?? '';
        if ($topic === '') {
            fwrite(STDERR, "Usage: period-wp-kit-agent impact <topic>\n");
            exit(1);
        }

        $impacts = [
            'PostAssets' => <<<MD
# Impact: PostAssets

## Summary
- Post-level CSS / JavaScript asset management.
- CSS input is compiled at save time and rendered from compiled meta.

## Primary implementation
- src/WordPress/PostAssets.php
- src/WordPress/PostAssetsRenderer.php
- src/WordPress/PostAssetsCompileService.php
- src/WordPress/PostAssetsCompilerInterface.php
- src/WordPress/ScssPhpPostAssetsCompiler.php

## Integration points
- src/WordPress/MetaBox.php
- src/WordPress/PostMetaManager.php
- src/WordPress/ScriptStyleRegistrar.php

## Tests
- tests/WordPress/PostAssetsTest.php
- tests/WordPress/PostAssetsCompileServiceTest.php
- tests/WordPress/ScssPhpPostAssetsCompilerTest.php
- tests/WordPress/MetaBoxTest.php

## Documentation
- docs/architecture-post-assets.md
- docs/development-roadmap.md

## Do not change casually
- MetaBox save flow must remain generic.
- Renderer must not compile assets.
- Compiler must not enqueue or render frontend output.
- Compile service must not hook save_post directly.
- Runtime compile should not be introduced.
MD,
        ];

        if (!isset($impacts[$topic])) {
            fwrite(STDERR, "Unknown topic: {$topic}\n");
            fwrite(STDERR, "Available topics: " . implode(', ', array_keys($impacts)) . "\n");
            exit(1);
        }

        echo $impacts[$topic] . "\n";
        break;

    default:
        echo <<<TXT
period-wp-kit-agent commands:

  period-wp-kit-agent scan
  period-wp-kit-agent grep <pattern>
  period-wp-kit-agent pack <file> [file...]
  period-wp-kit-agent test
  period-wp-kit-agent roadmap
  period-wp-kit-agent architecture
  period-wp-kit-agent context <topic>
  period-wp-kit-agent impact <topic>

Available context topics: PostAssets
Available impact topics: PostAssets

This version is read-only except running tests.
TXT;
}
